MAP_API_KEY=your_api_key_here
MAP_BASE_URL=https://api.olamaps.io
MAP_TIMEOUT_MS=5000
MAP_PROVIDER_NAME=ola
MAP_ROUTE_PREFERENCE=fastest
MAP_LINK_BASE_URL=https://www.google.com/maps?q=
