MAP_RETRY_DELAY_MS=150
ENABLE_PROVIDER_CACHE=true
PROVIDER_CACHE_TTL_MS=300000
SEARCH_CACHE_TTL_MS=180000
SEARCH_MAX_RESULTS=7

PORT=3000
